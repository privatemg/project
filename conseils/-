<style>
/* ===== CONSEILS PAGE STYLES ===== */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --gold:#B8860B;--cyan:#0097A7;--orange:#E06B00;--coral:#E05040;--violet:#7B5CC8;--green:#0E9F6E;--blue:#2563EB;
  --bg:#FFFFF8;--bg2:#FFF8DC;--bg3:#FFF2C2;--border:rgba(180,130,0,.18);
  --txt:#3D2B00;--txt2:#7A5C00;--txt3:#A0820A;
  --grad-page:linear-gradient(160deg,#FFFFF8 0%,#FFF8DC 50%,#FFF2C2 100%);
  --grad-nav:linear-gradient(90deg,#FFF3CC,#FFF9EC);
}

html{scroll-behavior:smooth}
body{font-family:'Montserrat',sans-serif;background:var(--grad-page);min-height:100vh;color:var(--txt);overflow-x:hidden;line-height:1.7}

/* ===== SEARCH BAR ===== */
.search-wrap{position:relative;max-width:600px;margin:0 auto 52px;animation:fadeUp .7s .3s both}
.search-wrap svg{position:absolute;left:18px;top:50%;transform:translateY(-50%);color:var(--txt3);pointer-events:none;transition:color .3s}
.search-input{width:100%;background:rgba(255,255,255,.75);border:1.5px solid rgba(180,130,0,.22) !important;border-radius:14px;backdrop-filter:blur(4px);padding:16px 20px 16px 50px;font-family:'Montserrat',sans-serif;font-size:15px;color:var(--txt);outline:none;transition:border-color .3s,box-shadow .3s}
.search-input:focus{border-color:rgba(248,186,8,.5);box-shadow:0 0 0 3px rgba(248,186,8,.08)}
.search-input:focus + svg,.search-wrap:focus-within svg{color:var(--gold)}
.search-input::placeholder{color:var(--txt3)}
.no-results{text-align:center;padding:60px 20px;color:var(--txt2);display:none;animation:fadeUp .4s both}
.no-results svg{margin-bottom:16px;opacity:.4}
.no-results p{font-size:15px}

/* ===== NAV ===== */
.nav{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:0 24px;background:linear-gradient(90deg,rgba(255,243,204,.95),rgba(255,249,236,.95));backdrop-filter:blur(20px);border-bottom:1px solid rgba(180,130,0,.2);transition:all .3s}
.nav-in{max-width:1200px;margin:0 auto;height:68px;display:flex;align-items:center;justify-content:space-between;gap:20px}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;font-weight:800;font-size:17px;letter-spacing:.5px;color:#3D2B00}
.nav-logo img{width:34px;height:34px;border-radius:8px}
.nav-logo .g{color:var(--gold)}
.nav-lk{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.nav-lk a{text-decoration:none;color:var(--txt2);font-size:13px;font-weight:600;padding:6px 10px;border-radius:8px;transition:color .2s,background .2s}
.nav-lk a:hover,.nav-lk a.active{color:#3D2B00;background:rgba(184,134,11,.15)}
.nav-cta{background:var(--gold);color:#000 !important;padding:9px 18px !important;border-radius:10px;font-weight:700 !important;font-size:13px !important;transition:transform .2s,box-shadow .2s !important}
.nav-cta:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(248,186,8,.3)}
.bur{display:none;background:none;border:none;cursor:pointer;padding:6px;flex-direction:column;gap:5px}
.bur s{display:block;width:22px;height:2px;background:#3D2B00;border-radius:2px;transition:all .3s;text-decoration:none}
.mob{display:none;flex-direction:column;padding:20px 24px;border-top:1px solid var(--border);gap:4px}
.mob.open{display:flex;background:linear-gradient(160deg,#FFF2C2,#FFE082);border-top:2px solid rgba(184,134,11,.3)}
.ml{text-decoration:none;color:#3D2B00;font-size:14px;font-weight:700;padding:10px 12px;border-radius:8px;transition:all .2s}
.ml:hover{color:#3D2B00;background:rgba(184,134,11,.25)}

/* Lang switcher */
.lang-sw{position:relative}
.lang-btn{display:flex;align-items:center;gap:6px;background:rgba(212,150,10,.08);border:1px solid var(--border);border-radius:8px;padding:6px 10px;cursor:pointer;color:var(--txt2);font-size:12px;font-weight:700;font-family:'Montserrat',sans-serif;transition:all .2s}
.lang-btn:hover{background:rgba(184,134,11,.15);color:#3D2B00}
.lang-btn .la{transition:transform .2s}
.lang-btn.open .la{transform:rotate(180deg)}
.lang-drop{position:absolute;top:calc(100% + 8px);right:0;background:#FFF8E0;border:1px solid var(--border);border-radius:10px;overflow:hidden;min-width:130px;opacity:0;transform:translateY(-8px);pointer-events:none;transition:all .2s;z-index:100}
.lang-drop.open{opacity:1;transform:translateY(0);pointer-events:all}
.lang-opt{display:flex;align-items:center;gap:8px;padding:10px 14px;cursor:pointer;font-size:13px;font-weight:600;color:var(--txt2);transition:all .2s}
.lang-opt:hover,.lang-opt.active{background:rgba(248,186,8,.08);color:#fff}
.lf{display:flex;align-items:center;flex-shrink:0}

/* mob lang */
.mob-lang-wrap{margin-bottom:8px}
.mob-lang-btn{display:flex;align-items:center;gap:6px;background:rgba(255,255,255,.5);border:1px solid rgba(184,134,11,.35);border-radius:8px;padding:8px 12px;cursor:pointer;color:#3D2B00;font-size:13px;font-weight:700;font-family:'Montserrat',sans-serif;width:100%;transition:all .2s}
.mob-lang-drop{display:none;flex-direction:column;background:#FFF3CC;border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-top:6px}
.mob-lang-drop.open{display:flex}
.mob-lang-opt{display:flex;align-items:center;gap:8px;padding:10px 14px;cursor:pointer;font-size:13px;font-weight:600;color:#3D2B00;background:none;border:none;font-family:'Montserrat',sans-serif;transition:all .2s}
.mob-lang-opt:hover,.mob-lang-opt.active{background:rgba(184,134,11,.2);color:#3D2B00}
.mob-la{transition:transform .2s;margin-left:auto}
.mob-lang-btn.open .mob-la{transform:rotate(180deg)}

/* ===== HERO ===== */
.page-hero{padding:120px 24px 60px;text-align:center;position:relative;overflow:hidden;background:transparent}
.page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(184,134,11,.18) 0%,transparent 70%);pointer-events:none}
.page-hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(180,130,0,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(180,130,0,.08) 1px,transparent 1px);background-size:60px 60px;pointer-events:none}
.page-hero-in{max-width:800px;margin:0 auto;position:relative;z-index:2}
.pg-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(248,186,8,.08);border:1px solid rgba(248,186,8,.2);color:var(--gold);padding:6px 16px;border-radius:20px;font-size:12px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;margin-bottom:24px;animation:fadeUp .6s both}
.pg-h1{font-size:clamp(2rem,5vw,3.5rem);font-weight:800;line-height:1.15;margin-bottom:20px;animation:fadeUp .6s .1s both;color:#3D2B00}
.pg-h1 .gd{background:linear-gradient(135deg,#D4960A,#B8860B,#E06B00);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.pg-desc{color:var(--txt2);font-size:16px;max-width:600px;margin:0 auto 40px;animation:fadeUp .6s .2s both}

/* ===== CATEGORY FILTERS ===== */
.cat-filters{display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:48px;animation:fadeUp .6s .25s both}
.cat-btn{background:rgba(255,248,220,.7);border:1.5px solid rgba(180,130,0,.22);color:var(--txt2);padding:8px 18px;border-radius:20px;font-size:13px;font-weight:600;cursor:pointer;font-family:'Montserrat',sans-serif;transition:all .25s}
.cat-btn:hover{background:rgba(184,134,11,.15);color:#3D2B00;border-color:rgba(184,134,11,.4)}
.cat-btn.on{border-color:var(--gold);color:var(--gold);background:rgba(248,186,8,.08)}

/* ===== ARTICLES GRID ===== */
.main-content{max-width:1200px;margin:0 auto;padding:0 24px 100px;background:transparent}

.articles-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:28px}

.article-card{background:rgba(255,255,255,.8);border:1.5px solid rgba(180,130,0,.22);box-shadow:0 4px 20px rgba(180,130,0,.08);border-radius:20px;overflow:hidden;transition:transform .35s cubic-bezier(.22,1,.36,1),border-color .3s,box-shadow .3s;cursor:pointer;animation:fadeUp .6s both;display:flex;flex-direction:column;backdrop-filter:blur(6px)}
.article-card:hover{transform:translateY(-6px);border-color:rgba(184,134,11,.5);box-shadow:0 16px 40px rgba(180,130,0,.18)}
.article-card.hidden{display:none}

.ac-header{padding:28px 28px 0}
.ac-cat-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:12px;font-size:11px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;margin-bottom:16px}
.ac-cat-badge svg{flex-shrink:0}

.ac-title{font-size:18px;font-weight:800;line-height:1.35;margin-bottom:12px;color:#3D2B00;transition:color .2s}
.article-card:hover .ac-title{color:#B8860B}

.ac-excerpt{color:var(--txt2);font-size:14px;line-height:1.7;padding:0 28px 20px}
.ac-footer{padding:0 28px 24px;margin-top:auto;display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--border);padding-top:16px}
.ac-meta{display:flex;align-items:center;gap:8px;color:var(--txt3);font-size:12px;font-weight:600}
.ac-meta svg{opacity:.6}
.ac-read{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:700;color:#B8860B;text-decoration:none;transition:gap .2s}
.article-card:hover .ac-read{gap:10px}

/* Expanded article modal */
.article-modal-bg{position:fixed;inset:0;background:rgba(30,20,0,.6);z-index:2000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(8px)}
.article-modal-bg.open{opacity:1;pointer-events:all}
.article-modal{background:linear-gradient(160deg,#FFFFF8,#FFF8DC);border:1.5px solid rgba(180,130,0,.2);border-radius:24px;max-width:760px;width:100%;max-height:90vh;overflow-y:auto;padding:48px;position:relative;transform:translateY(20px) scale(.97);transition:transform .3s}
.article-modal-bg.open .article-modal{transform:translateY(0) scale(1)}
.modal-close{position:absolute;top:20px;right:20px;background:rgba(180,140,0,.1);border:none;cursor:pointer;width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--txt2);transition:all .2s}
.modal-close:hover{background:rgba(180,140,0,.2);color:#3D2B00}
.modal-cat{margin-bottom:16px}
.modal-title{font-size:clamp(1.3rem,3vw,2rem);font-weight:800;line-height:1.3;margin-bottom:20px;color:#3D2B00}
.modal-meta{display:flex;align-items:center;gap:16px;color:var(--txt3);font-size:12px;font-weight:600;margin-bottom:32px;padding-bottom:24px;border-bottom:1px solid var(--border)}
.modal-body{color:#5A4A1A;font-size:15px;line-height:1.85}
.modal-body h2{font-size:1.2rem;font-weight:800;color:#3D2B00;margin:28px 0 12px}
.modal-body h3{font-size:1rem;font-weight:700;color:var(--gold);margin:22px 0 10px}
.modal-body p{margin-bottom:16px}
.modal-body strong{color:#3D2B00;font-weight:700}
.modal-body ul,.modal-body ol{padding-left:20px;margin-bottom:16px}
.modal-body li{margin-bottom:8px}
.modal-cta{margin-top:36px;padding-top:24px;border-top:1px solid var(--border);text-align:center}
.modal-cta a{display:inline-flex;align-items:center;gap:8px;background:var(--gold);color:#000;padding:12px 28px;border-radius:12px;font-weight:800;font-size:14px;text-decoration:none;transition:transform .2s,box-shadow .2s}
.modal-cta a:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(248,186,8,.3)}

/* ===== FOOTER ===== */
.ft{background:linear-gradient(160deg,#FFF8DC,#FFF2C2);border-top:1px solid rgba(180,130,0,.22);padding:60px 24px 24px;position:relative}
.ft-top{position:absolute;top:-22px;left:50%;transform:translateX(-50%);width:44px;height:44px;background:var(--gold);border:none;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#000;transition:transform .2s,box-shadow .2s;box-shadow:0 4px 16px rgba(248,186,8,.3)}
.ft-top:hover{transform:translateX(-50%) translateY(-3px);box-shadow:0 8px 24px rgba(248,186,8,.4)}
.ft-g{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr;gap:48px;padding-bottom:40px;border-bottom:1px solid var(--border)}
.ft-br{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.ft-br img{width:34px;height:34px;border-radius:8px}
.ft-desc{color:var(--txt2);font-size:13px;line-height:1.7;margin-bottom:20px}
.ft-soc{display:flex;gap:10px}
.ft-soc a{width:36px;height:36px;border-radius:10px;background:rgba(212,150,10,.08);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--txt2);transition:all .2s;text-decoration:none}
.ft-soc a:hover{background:rgba(248,186,8,.1);border-color:rgba(248,186,8,.3);color:var(--gold)}
.ft h4{font-size:13px;font-weight:700;color:#3D2B00;margin-bottom:16px;letter-spacing:.5px;text-transform:uppercase}
.ft ul{list-style:none}
.ft ul li{margin-bottom:10px}
.ft ul a{color:var(--txt2);text-decoration:none;font-size:13px;transition:color .2s}
.ft ul a:hover{color:#3D2B00}
.ft-bot{max-width:1200px;margin:24px auto 0;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.ft-bot p{color:var(--txt3);font-size:12px}

/* WhatsApp float */
.waf{position:fixed;bottom:28px;right:28px;z-index:500;display:flex;align-items:center;gap:10px;background:#25D366;border-radius:50px;padding:12px 20px 12px 14px;text-decoration:none;box-shadow:0 8px 30px rgba(37,211,102,.35);transition:transform .25s,box-shadow .25s;animation:waPop 1s 1.5s both}
.waf:hover{transform:translateY(-3px);box-shadow:0 14px 40px rgba(37,211,102,.45)}
.wp{position:absolute;inset:0;border-radius:inherit;background:rgba(255,255,255,.12);animation:waRing 2s 2.5s infinite}
.wt{color:#fff;font-size:13px;font-weight:700;white-space:nowrap}
@keyframes waPop{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes waRing{0%{transform:scale(1);opacity:.4}100%{transform:scale(1.5);opacity:0}}

/* Scroll to top */
.stt{position:fixed;bottom:28px;left:28px;z-index:500;width:44px;height:44px;background:rgba(212,150,10,.1);border:1px solid rgba(180,140,0,.25);border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--txt2);transition:all .25s;opacity:0;pointer-events:none}
.stt.vis{opacity:1;pointer-events:all}
.stt:hover{background:rgba(184,134,11,.2);color:#3D2B00}

/* ===== ANIMATIONS ===== */
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}

.rv{opacity:0;transform:translateY(30px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1)}
.rv.vis{opacity:1;transform:translateY(0)}
.d1{transition-delay:.1s}
.d2{transition-delay:.2s}
.d3{transition-delay:.3s}
.d4{transition-delay:.4s}
.d5{transition-delay:.5s}

/* Article stagger */
.article-card:nth-child(1){animation-delay:.1s}
.article-card:nth-child(2){animation-delay:.18s}
.article-card:nth-child(3){animation-delay:.26s}
.article-card:nth-child(4){animation-delay:.34s}
.article-card:nth-child(5){animation-delay:.42s}
.article-card:nth-child(6){animation-delay:.5s}
.article-card:nth-child(7){animation-delay:.58s}
.article-card:nth-child(8){animation-delay:.66s}

/* Pulse separator */
.sep-line{width:60px;height:3px;background:linear-gradient(90deg,var(--gold),var(--orange));border-radius:2px;margin:16px auto 0;animation:fadeUp .6s .15s both}

/* Scrollbar */
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:#FDF8EE}
::-webkit-scrollbar-thumb{background:rgba(180,140,0,.2);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:rgba(248,186,8,.4)}

@media(max-width:768px){
  .nav-lk{display:none}
  .bur{display:flex}
  .ft-g{grid-template-columns:1fr}
  .articles-grid{grid-template-columns:1fr}
  .article-modal{padding:28px 20px}
}
</style>
</head>
